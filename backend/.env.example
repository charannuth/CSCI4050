PORT=3002
DATABASE_URL="file:./dev.db"
# comma-separated list, or * to allow all (dev-only)
CORS_ORIGIN=http://localhost:5173

# Auth + encryption
JWT_SECRET=replace-with-at-least-16-chars
JWT_EXPIRES_SEC=604800
CARD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
PUBLIC_APP_URL=http://localhost:5173
# optional, used for verify-email links sent by backend
API_PUBLIC_URL=http://localhost:3002

# Email
# - console: log messages to the server terminal only (nothing is sent to the internet).
# - smtp: send via real SMTP (required for Gmail, etc.).
MAIL_TRANSPORT=console

# Gmail example when MAIL_TRANSPORT=smtp (use an App Password, not your normal password):
# 1. Google Account → Security → 2-Step Verification ON
# 2. Security → App passwords → generate for "Mail"
# 3. Set SMTP_USER to your full Gmail address; SMTP_PASS to the 16-char app password (spaces optional)
# 4. Set MAIL_FROM to the same address, e.g. MAIL_FROM="My CES <you@gmail.com>"
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=My Cinema <you@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cinema CES <noreply@localhost>
