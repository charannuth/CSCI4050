generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMERATIONS
// ==========================================
enum MovieStatus {
  CURRENTLY_RUNNING
  COMING_SOON
}

// ==========================================
// USER & ACCOUNTS
// ==========================================
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String    // Will store the securely hashed password
  firstName      String
  lastName       String
  status         String   @default("ACTIVE") // Requirement for Active/Inactive users
  role           String   @default("CUSTOMER")

  // Many-to-Many relationship for the Favorites feature
  favoriteMovies Movie[]  @relation("UserFavorites")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==========================================
// CINEMA CORE
// ==========================================
model Movie {
  id          String      @id @default(cuid())
  title       String      @unique
  rating      String?
  description String?
  posterUrl   String?
  trailerUrl  String?
  genre       String
  status      MovieStatus @default(CURRENTLY_RUNNING)

  // Relationships
  showtimes   Showtime[]
  favoritedBy User[]      @relation("UserFavorites") // Links back to User

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([genre])
  @@index([status])
  @@index([title])
}

model Showtime {
  id        String   @id @default(cuid())
  startsAt  DateTime

  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([movieId])
  @@index([startsAt])
}