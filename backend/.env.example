PORT=3002
DATABASE_URL="file:./dev.db"
# comma-separated list, or * to allow all (dev-only)
CORS_ORIGIN=http://localhost:5173

# Auth & encryption (required)
JWT_SECRET=replace-with-a-long-random-string-at-least-16-chars
# 32-byte key, base64 — e.g. node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CARD_ENCRYPTION_KEY=
SESSION_COOKIE_NAME=ces_session
JWT_EXPIRES_SEC=604800
COOKIE_MAX_AGE_MS=604800000
# set COOKIE_SECURE=true behind HTTPS in production
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:5173
# Public URL of this API for links in email (omit to default to http://localhost:$PORT)
API_PUBLIC_URL=http://localhost:3002

# Email (optional — without SMTP, messages log to the server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cinema CES <noreply@localhost>
